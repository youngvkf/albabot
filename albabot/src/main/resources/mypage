<!DOCTYPE html>
<html lang="ko" xmlns:th="http://www.thymeleaf.org">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AlbaBot - 마이 페이지</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&display=swap');
* { margin:0; padding:0; box-sizing:border-box; }
:root {
  --primary: #0ABF8A; --primary-dark: #059669;
  --bg: #F0FDF9; --surface: #fff;
  --border: #D1FAE5; --text: #111827; --text2: #6B7280; --text3: #9CA3AF;
}
body { font-family: 'Noto Sans KR', sans-serif; background: var(--bg); min-height: 100vh; }
/* 프로필 헤더 */
.profile-header {
  background: linear-gradient(135deg, #0ABF8A, #059669);
  padding: 32px 24px 48px; color: white;
}
.profile-top { display: flex; align-items: center; gap: 16px; }
.avatar {
  width: 64px; height: 64px;
  background: rgba(255,255,255,0.25); border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 26px; font-weight: 900; color: white;
  border: 2px solid rgba(255,255,255,0.4);
}
.profile-name { font-size: 22px; font-weight: 700; }
.profile-email { font-size: 13px; opacity: 0.8; margin-top: 4px; }
.profile-info { display: flex; gap: 20px; margin-top: 16px; }
.profile-info-item { font-size: 13px; opacity: 0.85; }
.profile-info-item span { font-weight: 700; opacity: 1; }
/* 컨텐츠 */
.container {
  max-width: 820px; margin: -20px auto 0;
  padding: 0 16px 100px; position: relative; z-index: 1;
}
.section {
  background: var(--surface); border-radius: 18px; padding: 20px;
  margin-bottom: 12px; border: 1px solid var(--border);
}
.section-header {
  display: flex; justify-content: space-between; align-items: center;
  margin-bottom: 16px;
}
.section-title { font-size: 15px; font-weight: 700; color: var(--text); }
.section-link { font-size: 13px; color: var(--primary); font-weight: 600; text-decoration: none; }
/* 지원 현황 */
.apply-item {
  display: flex; justify-content: space-between; align-items: center;
  padding: 14px 0; border-bottom: 1px solid var(--border);
}
.apply-item:last-child { border-bottom: none; padding-bottom: 0; }
.apply-job-title { font-size: 14px; font-weight: 600; color: var(--text); }
.apply-job-sub { font-size: 12px; color: var(--text3); margin-top: 3px; }
.status-badge {
  padding: 5px 12px; border-radius: 8px; font-size: 12px; font-weight: 700;
  white-space: nowrap; flex-shrink: 0;
}
.status-PENDING  { background: #FEF9C3; color: #854D0E; }
.status-ACCEPTED { background: #ECFDF5; color: #065F46; }
.status-REJECTED { background: #FEF2F2; color: #991B1B; }
.empty-text { font-size: 14px; color: var(--text3); text-align: center; padding: 16px 0; }
/* 내 정보 */
.info-row {
  display: flex; justify-content: space-between;
  padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 14px;
}
.info-row:last-child { border-bottom: none; }
.info-key { color: var(--text3); font-weight: 500; }
.info-val { color: var(--text); font-weight: 600; }
/* 카테고리 태그 */
.cat-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 8px; }
.cat-tag {
  background: #ECFDF5; color: var(--primary-dark);
  padding: 4px 12px; border-radius: 20px;
  font-size: 12px; font-weight: 600;
}
/* 하단 네비 */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: var(--surface); border-top: 1px solid var(--border);
  display: flex; padding: 10px 0 14px;
  box-shadow: 0 -4px 16px rgba(0,0,0,0.06);
}
.nav-item {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; gap: 4px; cursor: pointer; text-decoration: none;
}
.nav-icon { font-size: 22px; }
.nav-label { font-size: 11px; color: var(--text3); font-weight: 500; }
.nav-item.active .nav-label { color: var(--primary); font-weight: 700; }
/* 로그아웃 */
.logout-section { padding: 8px 0; }
.logout-link {
  display: block; text-align: center; padding: 14px;
  color: #DC2626; font-size: 14px; font-weight: 600;
  text-decoration: none; border-radius: 12px;
  transition: background 0.15s;
}
.logout-link:hover { background: #FEF2F2; }
</style>
</head>
<body>
 
<!-- 프로필 헤더 -->
<div class="profile-header">
  <div class="profile-top">
    <div class="avatar" th:text="${loginUser != null} ? ${#strings.substring(loginUser.name,0,1)} : '?'">장</div>
    <div>
      <div class="profile-name" th:text="${loginUser?.name} ?: '사용자'">장화인</div>
      <div class="profile-email" th:text="${loginUser?.email} ?: ''">이메일</div>
    </div>
  </div>
  <div class="profile-info">
    <div class="profile-info-item">지역 <span th:text="${loginUser?.region} ?: '-'">서울 강남구</span></div>
    <div class="profile-info-item">선호 시간 <span th:text="${loginUser?.preferredTime} ?: '-'">주말</span></div>
  </div>
</div>
 
<div class="container">
 
  <!-- 선호 카테고리 -->
  <div class="section">
    <div class="section-header">
      <div class="section-title">선호 카테고리</div>
    </div>
    <div class="cat-tags">
      <span th:each="cat : ${categories}" class="cat-tag" th:text="${cat.category}">카테고리</span>
      <span th:if="${#lists.isEmpty(categories)}" style="font-size:14px;color:#9CA3AF;">설정된 카테고리가 없어요</span>
    </div>
  </div>
 
  <!-- 지원 현황 -->
  <div class="section">
    <div class="section-header">
      <div class="section-title">내 지원 현황</div>
      <a href="/my/applications" class="section-link">전체보기</a>
    </div>
    <div th:each="app : ${recentApplications}" class="apply-item">
      <div>
        <div class="apply-job-title" th:text="${app.jobTitle} ?: '공고 제목'">공고명</div>
        <div class="apply-job-sub"   th:text="${app.appliedAt}">지원일</div>
      </div>
      <div class="status-badge"
           th:classappend="'status-' + ${app.status}"
           th:text="${app.status == 'PENDING'} ? '검토중' : (${app.status == 'ACCEPTED'} ? '합격 🎉' : '불합격')">
        상태
      </div>
    </div>
    <div th:if="${#lists.isEmpty(recentApplications)}" class="empty-text">아직 지원한 공고가 없어요</div>
  </div>
 
  <!-- 내 정보 -->
  <div class="section">
    <div class="section-header">
      <div class="section-title">내 정보</div>
    </div>
    <div class="info-row">
      <span class="info-key">이름</span>
      <span class="info-val" th:text="${loginUser?.name} ?: '-'">이름</span>
    </div>
    <div class="info-row">
      <span class="info-key">이메일</span>
      <span class="info-val" th:text="${loginUser?.email} ?: '-'">이메일</span>
    </div>
    <div class="info-row">
      <span class="info-key">연락처</span>
      <span class="info-val" th:text="${loginUser?.phone} ?: '-'">전화번호</span>
    </div>
    <div class="info-row">
      <span class="info-key">지역</span>
      <span class="info-val" th:text="${loginUser?.region} ?: '-'">지역</span>
    </div>
    <div class="info-row">
      <span class="info-key">선호 시간대</span>
      <span class="info-val" th:text="${loginUser?.preferredTime} ?: '-'">선호시간</span>
    </div>
  </div>
 
  <!-- 로그아웃 -->
  <div class="section logout-section">
    <a href="/logout" class="logout-link">로그아웃</a>
  </div>
 
</div>
 
<!-- 하단 네비 -->
<div class="bottom-nav">
  <a href="/jobs" class="nav-item">
    <div class="nav-icon">🏠</div>
    <div class="nav-label">홈</div>
  </a>
  <a href="/my/applications" class="nav-item">
    <div class="nav-icon">📋</div>
    <div class="nav-label">지원현황</div>
  </a>
  <a href="/mypage" class="nav-item active">
    <div class="nav-icon">👤</div>
    <div class="nav-label" style="color:#0ABF8A">마이</div>
  </a>
</div>
 
</body>
</html>
